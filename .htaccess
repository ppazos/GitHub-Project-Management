Options -Indexes +FollowSymLinks
RewriteEngine On
RewriteBase /GitHub-Project-Management/

# Deny direct access to lib/ and .env
RewriteRule ^lib/         - [F,L]
RewriteRule ^\.env$       - [F,L]

# Route root and /app to the SPA shell
RewriteRule ^$            public/index.php [L]
RewriteRule ^app(/.*)?$   public/index.php [L]

# Auth endpoints
RewriteRule ^auth/login$     auth/login.php    [L]
RewriteRule ^auth/callback$  auth/callback.php [L]
RewriteRule ^auth/logout$    auth/logout.php   [L]

# API endpoints
RewriteRule ^api/me$           api/me.php           [L]
RewriteRule ^api/repos$        api/repos.php        [L]
RewriteRule ^api/milestones$   api/milestones.php   [L]
RewriteRule ^api/issues$       api/issues.php       [L]
RewriteRule ^api/issue_update$ api/issue_update.php [L]
RewriteRule ^api/issue_order$       api/issue_order.php       [L]
RewriteRule ^api/milestone_create$  api/milestone_create.php  [L]
RewriteRule ^api/milestone_stats$   api/milestone_stats.php   [L]
