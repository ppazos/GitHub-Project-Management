GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost/GitHub-Project-Management/auth/callback

DB_HOST=localhost
DB_NAME=kanban
DB_USER=root
DB_PASS=

APP_URL=http://localhost/GitHub-Project-Management
# Subdirectory the app lives under. Empty string if served from domain root.
APP_BASE=/GitHub-Project-Management

SESSION_SECRET=replace-with-random-64-char-string

# Generate with: php -r "echo base64_encode(random_bytes(32));"
ENCRYPT_KEY=replace-with-base64-encoded-32-byte-key
